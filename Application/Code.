    private void setupApplicationIcon() {
        java.net.URL iconUrl = getClass().getResource("File_Logo.png");
        if (iconUrl != null) {
            setIconImage(new ImageIcon(iconUrl).getImage());
        }
    }

    private void setupFileManager() {
        baseDirectory = new File(System.getProperty("user.home"), "Documents" + File.separator + "File_Manager");
        if (!baseDirectory.exists()) {
            baseDirectory.mkdirs();
        }
        currentDirectory = baseDirectory;

        DefaultTableModel model = new DefaultTableModel(
                new String[]{"Name", "Date", "Size", "Empty"}, 0) {
            @Override
            public boolean isCellEditable(int row, int column) {
                return false;
            }

            @Override
            public Class<?> getColumnClass(int columnIndex) {
                switch (columnIndex) {
                    case 3:
                        return Boolean.class;
                    default:
                        return String.class;
                }
            }
        };
        jTable1.setModel(model);
        jTable1.getColumnModel().getColumn(0).setCellRenderer(new FileIconRenderer());
        jTable1.setRowHeight(28);

        jTable1.addMouseListener(new MouseAdapter() {
            @Override
            public void mouseClicked(MouseEvent e) {
                int row = jTable1.rowAtPoint(e.getPoint());
                int column = jTable1.columnAtPoint(e.getPoint());
                if (row < 0) {
                    return;
                }

                File selected = getFileForRow(row);
                if (selected == null || !selected.exists()) {
                    return;
                }

                if (selected.isDirectory()) {
                    if (column == 0 && e.getClickCount() == 1) {
                        openFolderInFileExplorer(selected);
                    } else if (e.getClickCount() == 2) {
                        openFolderInFileExplorer(selected);
                    }
                } else if (e.getClickCount() == 2) {
                    openFileWithSystem(selected);
                }
            }
        });

        refreshTable();
        updateWindowTitle();
    }

    private void updateWindowTitle() {
        setTitle("File Manager - " + currentDirectory.getAbsolutePath());
    }

    private void add_fileActionPerformed(java.awt.event.ActionEvent evt) {                                         
        JFileChooser chooser = new JFileChooser();
        chooser.setDialogTitle("Select a file or image to add");
        chooser.setFileSelectionMode(JFileChooser.FILES_ONLY);
        int result = chooser.showOpenDialog(this);
        if (result == JFileChooser.APPROVE_OPTION) {
            File selectedFile = chooser.getSelectedFile();
            try {
                copyFileToCurrentDirectory(selectedFile);
                refreshTable();
                JOptionPane.showMessageDialog(this,
                        "File added to:\n" + currentDirectory.getAbsolutePath(),
                        "Success",
                        JOptionPane.INFORMATION_MESSAGE);
            } catch (IOException ex) {
                JOptionPane.showMessageDialog(this,
                        "Could not add file:\n" + ex.getMessage(),
                        "Error",
                        JOptionPane.ERROR_MESSAGE);
            }
        }
    }                                        

    private void open_fileActionPerformed(java.awt.event.ActionEvent evt) {                                          
        int selectedRow = jTable1.getSelectedRow();
        if (selectedRow >= 0) {
            File selected = getFileForRow(selectedRow);
            if (selected != null) {
                if (selected.isDirectory()) {
                    openFolderInFileExplorer(selected);
                } else {
                    openFileWithSystem(selected);
                }
                return;
            }
        }

        JFileChooser chooser = new JFileChooser(currentDirectory);
        chooser.setDialogTitle("Open File");
        chooser.setFileSelectionMode(JFileChooser.FILES_ONLY);
        int result = chooser.showOpenDialog(this);
        if (result == JFileChooser.APPROVE_OPTION) {
            openFileWithSystem(chooser.getSelectedFile());
        }
    }                                         

    private void create_fileActionPerformed(java.awt.event.ActionEvent evt) {                                            
        String folderName = JOptionPane.showInputDialog(this, "Folder Name:");
        if (folderName == null) {
            return;
        }

        folderName = folderName.trim();
        if (folderName.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Please enter a folder name.");
            return;
        }

        File newFolder = new File(currentDirectory, folderName);
        if (newFolder.exists()) {
            JOptionPane.showMessageDialog(this, "Folder already exists.");
            return;
        }

        if (newFolder.mkdir()) {
            refreshTable();
            openFolderInFileExplorer(newFolder);
            JOptionPane.showMessageDialog(this,
                    "Folder created successfully.\nIt is visible in the app and in File Explorer.",
                    "Success",
                    JOptionPane.INFORMATION_MESSAGE);
        } else {
            JOptionPane.showMessageDialog(this, "Failed to create the folder.");
        }
    }                                           

    private void btnDeleteActionPerformed(java.awt.event.ActionEvent evt) {                                          
        deleteSelectedItem();
    }                                         

    private void deleteSelectedItem() {
        int selectedRow = jTable1.getSelectedRow();
        if (selectedRow < 0) {
            JOptionPane.showMessageDialog(this, "Please select a file or folder to delete.");
            return;
        }

        DefaultTableModel model = (DefaultTableModel) jTable1.getModel();
        String name = (String) model.getValueAt(selectedRow, 0);
        if ("..".equals(name)) {
            JOptionPane.showMessageDialog(this, "You cannot delete the parent folder entry.");
            return;
        }

        File selected = getFileForRow(selectedRow);
        if (selected == null || !selected.exists()) {
            JOptionPane.showMessageDialog(this, "File or folder not found.");
            refreshTable();
            return;
        }

        String itemType = selected.isDirectory() ? "folder" : "file";
        int confirm = JOptionPane.showConfirmDialog(
                this,
                "Are you sure you want to delete this " + itemType + "?\n" + selected.getName(),
                "Confirm Delete",
                JOptionPane.YES_NO_OPTION,
                JOptionPane.WARNING_MESSAGE);
        if (confirm != JOptionPane.YES_OPTION) {
            return;
        }

        try {
            deleteFileOrFolder(selected);
            refreshTable();
            JOptionPane.showMessageDialog(this,
                    "Deleted successfully from the app and File Explorer.",
                    "Success",
                    JOptionPane.INFORMATION_MESSAGE);
        } catch (IOException ex) {
            JOptionPane.showMessageDialog(this,
                    "Could not delete:\n" + ex.getMessage(),
                    "Error",
                    JOptionPane.ERROR_MESSAGE);
        }
    }

    private void deleteFileOrFolder(File file) throws IOException {
        if (!file.exists()) {
            return;
        }
        if (file.isDirectory()) {
            File[] children = file.listFiles();
            if (children != null) {
                for (File child : children) {
                    deleteFileOrFolder(child);
                }
            }
        }
        if (!file.delete()) {
            throw new IOException("Failed to delete: " + file.getAbsolutePath());
        }
    }

    private void refreshTable() {
        DefaultTableModel model = (DefaultTableModel) jTable1.getModel();
        model.setRowCount(0);

        if (currentDirectory.getParentFile() != null
                && !currentDirectory.equals(baseDirectory)) {
            model.addRow(new Object[]{"..", "", "", false});
        }

        File[] files = currentDirectory.listFiles();
        if (files != null) {
            SimpleDateFormat dateFormat = new SimpleDateFormat("dd/MM/yyyy");
            for (File file : files) {
                String name = file.getName();
                String date = dateFormat.format(new Date(file.lastModified()));
                String size = file.isDirectory() ? "--" : formatFileSize(file.length());
                boolean isEmpty = file.isDirectory()
                        && (file.list() == null || file.list().length == 0);

                model.addRow(new Object[]{name, date, size, isEmpty});
            }
        }
    }

    private String formatFileSize(long bytes) {
        if (bytes < 1024) {
            return bytes + " B";
        }
        return (bytes / 1024) + " KB";
    }

    private void copyFileToCurrentDirectory(File sourceFile) throws IOException {
        File destination = new File(currentDirectory, sourceFile.getName());
        Files.copy(sourceFile.toPath(), destination.toPath(), StandardCopyOption.REPLACE_EXISTING);
    }

    private File getFileForRow(int row) {
        DefaultTableModel model = (DefaultTableModel) jTable1.getModel();
        String name = (String) model.getValueAt(row, 0);
        if (name == null) {
            return null;
        }
        if ("..".equals(name)) {
            return currentDirectory.getParentFile();
        }
        return new File(currentDirectory, name);
    }

    private void enterDirectory(File directory) {
        if (directory == null || !directory.isDirectory()) {
            return;
        }
        currentDirectory = directory;
        refreshTable();
        updateWindowTitle();
    }

    private void openFileWithSystem(File file) {
        if (file == null || !file.exists()) {
            JOptionPane.showMessageDialog(this, "File not found.");
            return;
        }
        if (file.isDirectory()) {
            openFolderInFileExplorer(file);
            return;
        }
        if (!Desktop.isDesktopSupported()) {
            JOptionPane.showMessageDialog(this, "Opening files is not supported on this system.");
            return;
        }
        try {
            Desktop.getDesktop().open(file);
        } catch (IOException ex) {
            JOptionPane.showMessageDialog(this,
                    "Could not open file:\n" + ex.getMessage(),
                    "Error",
                    JOptionPane.ERROR_MESSAGE);
        }
    }

    private void openFolderInFileExplorer(File folder) {
        if (folder == null || !folder.isDirectory()) {
            return;
        }
        enterDirectory(folder);
        if (!Desktop.isDesktopSupported()) {
            JOptionPane.showMessageDialog(this, "File Explorer is not supported on this system.");
            return;
        }
        try {
            Desktop.getDesktop().open(folder);
        } catch (IOException ex) {
            JOptionPane.showMessageDialog(this,
                    "Could not open folder in File Explorer:\n" + ex.getMessage(),
                    "Error",
                    JOptionPane.ERROR_MESSAGE);
        }
    }

    private class FileIconRenderer extends DefaultTableCellRenderer {
        private final Icon folderIcon = UIManager.getIcon("FileView.directoryIcon");
        private final Icon fileIcon = UIManager.getIcon("FileView.fileIcon");

        @Override
        public Component getTableCellRendererComponent(
                JTable table, Object value, boolean isSelected, boolean hasFocus, int row, int column) {
            super.getTableCellRendererComponent(table, value, isSelected, hasFocus, row, column);

            String name = value == null ? "" : value.toString();
            setText(name);

            if ("..".equals(name)) {
                setIcon(folderIcon);
            } else {
                File file = getFileForRow(row);
                if (file != null && file.isDirectory()) {
                    setIcon(folderIcon);
                } else {
                    setIcon(fileIcon);
                }
            }

            return this;
        }
    }

